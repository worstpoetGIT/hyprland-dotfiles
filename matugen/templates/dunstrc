[global]
    progress_bar_corner_radius = 8
    icon_corner_radius = 8
    transparency = 15
    frame_color = "#ffffff30"
    font = SF Pro Display 11
    corner_radius = 12

[urgency_low]
    background = "{{colors.surface.default.hex}}ee"
    foreground = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.outline_variant.default.hex}}"
    timeout = 5

[urgency_normal]
    background = "{{colors.surface.default.hex}}ee"
    foreground = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.primary.default.hex}}"
    timeout = 8

[urgency_critical]
    background = "{{colors.surface.default.hex}}ee"
    foreground = "{{colors.on_surface.default.hex}}"
    frame_color = "{{colors.tertiary.default.hex}}"
    timeout = 0
