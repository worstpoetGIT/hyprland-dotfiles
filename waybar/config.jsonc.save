{
  "layer": "top",
  "position": "top",

  "modules-left": ["hyprland/window", "cpu", "memory", "disk", "temperature", "custom/gpu"],
  "modules-center": ["hyprland/workspaces", "clock", "custom/brightness", "custom/screenshot"],
  "modules-right": ["custom/bluetooth", "network", "pulseaudio", "pulseaudio/slider", "battery","power-profiles-daemon"],
  "hyprland/window": {
    "format": "{}",
    "max-length": 60,
    "separate-outputs": true
  },

  "clock": {
  "interval": 1,
  "tooltip": false,
  "format": "{:%H:%M:%S}",
  "format-alt": "{:%a, %d %b %Y}",
},

"custom/brightness": {
  "exec": "brightnessctl -m | awk -F, '{gsub(/%/,\"\",$4); b=$4; r=int((b+2.5)/5)*5; print \"σΑÉ†   \" r}'",
  "interval": 1,
  "tooltip": false
},

"custom/screenshot": {
    "format": "οÄΑ",
    "tooltip": "Screenshot",
    "on-click": "hyprshot -m region",
    "on-click
},

"network": {
    "format-wifi": "ο΅Ϊ    {essid}",
    "format-ethernet": "σΑàÄ   Wired",
    "format-disconnected": "σΑ•Σ   Offline",
    "tooltip": false,
    "on-click": "~/.config/waybar/scripts/wifi-menu.sh"
  },

"pulseaudio": {
  "format": "σΑ΄΄,   {volume}%",
  "format-muted": "σΑ΄΄   muted",
  "tooltip": false,
  "max-volume": 150
},

"pulseaudio/slider": {
  "min": 0,
  "max": 150,
  "orientation": "horizontal"
},

  "custom/bluetooth": {
    "exec": "~/.config/waybar/scripts/bluetooth-status.sh",
    "interval": 2,
    "signal": 8,
    "return-type": "json",
    "on-click": "~/.config/waybar/scripts/bluetooth-toggle.sh",
    "on-click-right": "blueman-manager"
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}",
    "format-charging": "σΑ²³  {capacity}",
    "format-plugged": "σΑ²³   {capacity}",
    "format-full": "σΑ¹Ι   100",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ¹Ι"],
    "tooltip": false
  },

"power-profiles-daemon": {
  "format": "{icon}",
  "tooltip": false,
  "format-icons": {
    "default": "οÉß",
    "performance": "σΑ™Ö",
    "balanced": "σΑΨÖ",
    "power-saver": "σΑ™É"
  }
},

"cpu": {
  "format": "σΑ‰ö  {usage}%",
  "tooltip": false
},

"memory": {
  "format": "σΑç¦  {}%",
  "tooltip": false
},

"disk": {
  "interval": 30,
  "format": "σΑ΄ä  {percentage_used}%",
  "path": "/",
  "tooltip": false
},

"temperature": {
  "critical-threshold": 80,
  "format": "σΑîè  {temperatureC}¬ΑC",
  "tooltip": false
},

  "format": "{icon}  {capacity}%",
  "format-charging": "σΑ²³  {capacity}%",
  "format-plugged": "σΑ²³  {capacity}%",
  "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ¹Ι"],
  "tooltip": false
},

"custom/gpu": {
  "exec": "~/.config/waybar/scripts/gpu-status.sh",
  "interval": 2,
  "return-type": "json",
  "tooltip": false
}
}
